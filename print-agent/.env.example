# Token gerado no /caixa > Impressoras > Agentes
AGENT_TOKEN=cole_o_token_aqui

# URL base da API (produção)
API_BASE_URL=https://triviano.com.br

# Intervalos (ms)
POLL_INTERVAL_MS=2000
HEARTBEAT_INTERVAL_MS=30000

# Encoding padrão. Override por impressora pode ser configurado no admin
# via config_impressoras.encoding. Ex.: cp850, cp860, utf8.
PRINTER_ENCODING=cp850

# Log em arquivo (opcional). Deixe vazio para só stdout.
LOG_FILE=./agent.log

# Largura em colunas da impressora (58mm=32, 80mm=48)
PRINTER_COLUMNS=48

# Timeout de conexão TCP (ms)
TCP_TIMEOUT_MS=5000
